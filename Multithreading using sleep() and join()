class MyThread extends Thread {
    public void run() {
        for (int i = 1; i <= 5; i++) {
            System.out.println("Thread: " + i);
        }
    }
}

public class Main {
    public static void main(String[] args) throws InterruptedException {
        MyThread t = new MyThread();

        Thread.sleep(500);

        t.start();

        t.join();

        System.out.println("Main Thread Finished");
    }
}
