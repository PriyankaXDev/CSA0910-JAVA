public class Main {
    public static void main(String[] args) {

        int[][] a = {
            {1, 2},
            {5, 3}
        };

        int[][] b = {
            {2, 3},
            {4, 1}
        };

        System.out.println("Matrix Addition:");

        for (int i = 0; i < 2; i++) {
            for (int j = 0; j < 2; j++) {
                System.out.print((a[i][j] + b[i][j]) + " ");
            }
            System.out.println();
        }
    }
}
