public class Main {
    public static void main(String[] args) {
        int n = 4;
        int terms = n * 2;
        int a = 0, b = 1;
        int sum = 0;

        for (int i = 0; i <= terms; i++) {
            if (i % 2 == 0) {
                sum += a;
            }
            int c = a + b;
            a = b;
            b = c;
        }

        System.out.println("N = " + n);
        System.out.println("Even Index Fibonacci Sum = " + sum);
    }
}
