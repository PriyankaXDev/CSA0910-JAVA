public class Main {
    public static void main(String[] args) {
        int num = 14567;
        int rev = 0;
        int temp = num;

        while (temp != 0) {
            int digit = temp % 10;
            rev = rev * 10 + digit;
            temp = temp / 10;
        }

        System.out.println("Number: " + num);
        System.out.println("Reverse Number: " + rev);
    }
}
