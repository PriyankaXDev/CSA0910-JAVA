public class Main {
    public static void main(String[] args) {
        int num = 121;
        int temp = num;
        int reverse = 0;

        while (temp != 0) {
            int digit = temp % 10;
            reverse = reverse * 10 + digit;
            temp = temp / 10;
        }

        if (num == reverse) {
            System.out.println(num + " is a Palindrome Number");
        } else {
            System.out.println(num + " is Not a Palindrome Number");
        }
    }
}
