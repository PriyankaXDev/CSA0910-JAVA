import java.util.Arrays;

class SortData<T extends Comparable<T>> {
    T[] data;

    SortData(T[] data) {
        this.data = data;
    }

    void sort() {
        Arrays.sort(data);
    }

    void display() {
        for (T value : data) {
            System.out.print(value + " ");
        }
        System.out.println();
    }
}

public class Main {
    public static void main(String[] args) {
        Integer[] numbers = {5, 2, 8, 1, 3};
        String[] names = {"Banana", "Apple", "Orange", "Mango"};

        SortData<Integer> num = new SortData<>(numbers);
        SortData<String> str = new SortData<>(names);

        System.out.println("Sorted Integers:");
        num.sort();
        num.display();

        System.out.println("Sorted Strings:");
        str.sort();
        str.display();
    }
}
